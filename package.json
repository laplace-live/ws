{
  "name": "@laplace.live/ws",
  "version": "7.1.9",
  "description": "LAPLACE Live! flavored bilibili live WebSocket/TCP API",
  "type": "module",
  "main": "./dist/index.js",
  "browser": "./dist/browser.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "test": "bun test --timeout 5000",
    "prepublishOnly": "bun run build",
    "release": "changeset publish",
    "version": "changeset version",
    "lint": "biome check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laplace-live/ws.git"
  },
  "keywords": [
    "bilibili",
    "api",
    "websocket",
    "live",
    "ws",
    "tcp"
  ],
  "author": "simon3000 <simon3000@163.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/laplace-live/ws/issues"
  },
  "homepage": "https://github.com/laplace-live/ws#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@laplace.live/internal": "^1.3.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.12",
    "playwright": "^1.59.1",
    "tsdown": "^0.21.9",
    "typescript": "^5.9.3"
  }
}
